{
    "name": "wmpotify",
    "version": "0.1",
    "description": "A Windows Media Player 11 inspired Spicetify theme for Spotify",
    "scripts": {
        "build": "node build.ts build --experimental-strip-types",
        "apply": "node build.ts apply --experimental-strip-types",
        "build-local": "node build.ts build-local --experimental-strip-types"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Ingan121/WMPotify.git"
    },
    "keywords": [
        "css",
        "scss",
        "spicetify",
        "spotify",
        "theme",
        "wmp"
    ],
    "author": "Ingan121",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/Ingan121/WMPotify/issues"
    },
    "homepage": "https://github.com/Ingan121/WMPotify",
    "type": "module",
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@types/postcss-import": "^14.0.3",
        "cssnano": "^5.1.7",
        "esbuild": "^0.27.0",
        "mkdirp": "^1.0.4",
        "postcss": "^8.3.5",
        "postcss-base64": "^0.7.1",
        "postcss-calc": "^10.0.2",
        "postcss-import": "^16.1.0",
        "postcss-nested": "^7.0.2"
    },
    "dependencies": {
        "@types/chrome": "^0.1.36",
        "@types/react": "^19.2.10"
    }
}
